APP_NAME=Journal
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-public-url.example

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite
DB_FOREIGN_KEYS=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

RUN_DEMO_SEEDER=true
DEMO_ADMIN_EMAIL=admin@journal.demo
DEMO_ADMIN_PASSWORD=change-this-admin-password
DEMO_TEACHER_EMAIL=teacher@journal.demo
DEMO_TEACHER_PASSWORD=change-this-teacher-password
DEMO_STUDENT_EMAIL=student@journal.demo
DEMO_STUDENT_PASSWORD=change-this-student-password

VITE_APP_NAME="${APP_NAME}"
